alias grep='grep --color'

alias up='docker-compose up -d'
alias down='docker-compose down'

alias gs="git status"
v(){
	if [[ $@ == "zshrc" ]];then
		command nvim ~/.zshrc
	elif [[ $@ == "aliases" ]]; then
		command nvim ~/.bash_aliases
	else
		command nvim "$@"
	fi
}
alias vi='nvim'
alias vim='nvim'
