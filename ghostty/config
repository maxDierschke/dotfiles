# See https://ghostty.org/docs/config/reference

# reload config with CTRL+SHIFT+,

# Look
theme = Gruvbox Dark
background-opacity = .72
font-family = "JetBrainsMonoNL Nerd Font"
font-size = 16

# Window
mouse-hide-while-typing = true
window-decoration = server

# Other stuff
link-url = true
auto-update = check
